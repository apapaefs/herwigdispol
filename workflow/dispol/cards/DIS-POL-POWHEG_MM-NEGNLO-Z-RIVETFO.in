# -*- ThePEG-repository -*-

##################################################
# Photon-only NLO DIS — PP polarization
# Diagnostic: isolate NLO polarized machinery from γ+Z complications
##################################################

read snippets/EPCollider.in
read snippets/PolarizedEP.in

set /Herwig/Particles/e-:PDF /Herwig/Partons/NoPDF
set /Herwig/Particles/e+:PDF /Herwig/Partons/NoPDF

##################################################
# Polarized PDF
##################################################

create ThePEG::LHAPDF /Herwig/Partons/DiffPDF
set /Herwig/Partons/DiffPDF:RemnantHandler /Herwig/Partons/HadronRemnants
set /Herwig/Partons/DiffPDF:PDFName BDSSV24-NNLO

set  /Herwig/Partons/EPPolarizedExtractor:SecondLongitudinalDifferencePDF /Herwig/Partons/DiffPDF
set  /Herwig/Partons/EPPolarizedExtractor:FirstLongitudinalPolarization -1
set  /Herwig/Partons/EPPolarizedExtractor:SecondLongitudinalPolarization -1

set /Herwig/Samplers/Sampler:BinSampler:InitialPoints 1000000

##################################################
# Technical parameters for this run
##################################################
cd /Herwig/Generators
set EventGenerator:MaxErrors 1000000
set /Herwig/Shower/ShowerHandler:PDFB /Herwig/Partons/ShowerLOPDF
set /Herwig/Partons/MPIExtractor:SecondPDF  /Herwig/Partons/MPIPDF
set /Herwig/Shower/ShowerHandler:Interactions QEDQCD


create ThePEG::LHAPDF /Herwig/Partons/LHAPDF ThePEGLHAPDF.so
set /Herwig/Partons/LHAPDF:PDFName PDF4LHC15_nnlo_100_pdfas
set /Herwig/Partons/HardLOPDF:PDFName PDF4LHC15_nnlo_100_pdfas
set /Herwig/Partons/ShowerNLOPDF:PDFName PDF4LHC15_nnlo_100_pdfas
set /Herwig/Partons/RemnantDecayer:AllowTop Yes
set /Herwig/Partons/RemnantDecayer:DISRemnantOption AllParticles
set /Herwig/Partons/RemnantDecayer:DISOneRemnantFallback RelaxMass
set /Herwig/Partons/LHAPDF:RemnantHandler /Herwig/Partons/HadronRemnants
set /Herwig/Particles/p+:PDF /Herwig/Partons/LHAPDF
set /Herwig/Partons/EPPolarizedExtractor:SecondPDF  /Herwig/Partons/LHAPDF
set /Herwig/Partons/HardNLOPDF:PDFName PDF4LHC15_nnlo_100_pdfas
set /Herwig/Partons/ShowerLOPDF:PDFName PDF4LHC15_nnlo_100_pdfas


set EventGenerator:EventHandler:BeamA /Herwig/Particles/e-
set EventGenerator:EventHandler:LuminosityFunction:BeamEMaxA 18.*GeV
set EventGenerator:EventHandler:BeamB /Herwig/Particles/p+
set EventGenerator:EventHandler:LuminosityFunction:BeamEMaxB 275.*GeV

set /Herwig/EventHandlers/EventHandler:Cuts:ScaleMin 0.0*GeV2
set /Herwig/EventHandlers/EventHandler:Cuts:X1Min 1E-5
set /Herwig/EventHandlers/EventHandler:Cuts:X2Min 1E-5
set /Herwig/Cuts/NeutralCurrentCut:MinW2 0*GeV2
set /Herwig/Cuts/NeutralCurrentCut:MaxW2 1E99*GeV2
set /Herwig/Cuts/NeutralCurrentCut:MinQ2 49.*GeV2
set /Herwig/Cuts/NeutralCurrentCut:MaxQ2 2500.*GeV2
set /Herwig/Cuts/NeutralCurrentCut:Miny 0.2
set /Herwig/Cuts/NeutralCurrentCut:Maxy 0.6
set /Herwig/Cuts/Cuts:MHatMin 0.

# set the electron/positron hard process mass to zero
set /Herwig/Particles/e-:HardProcessMass 0
set /Herwig/Particles/e+:HardProcessMass 0

# set the quark hard process masses to zero for massless DIS comparisons
set /Herwig/Particles/u:HardProcessMass 0*GeV
set /Herwig/Particles/ubar:HardProcessMass 0*GeV
set /Herwig/Particles/d:HardProcessMass 0*GeV
set /Herwig/Particles/dbar:HardProcessMass 0*GeV
set /Herwig/Particles/s:HardProcessMass 0*GeV
set /Herwig/Particles/sbar:HardProcessMass 0*GeV
set /Herwig/Particles/c:HardProcessMass 0*GeV
set /Herwig/Particles/cbar:HardProcessMass 0*GeV
set /Herwig/Particles/b:HardProcessMass 0*GeV
set /Herwig/Particles/bbar:HardProcessMass 0*GeV

# align nominal masses with the hard-process masses for consistent massless plain-run tests
do /Herwig/Particles/e-:AdjustNominalMass
do /Herwig/Particles/e+:AdjustNominalMass
do /Herwig/Particles/u:AdjustNominalMass
do /Herwig/Particles/ubar:AdjustNominalMass
do /Herwig/Particles/d:AdjustNominalMass
do /Herwig/Particles/dbar:AdjustNominalMass
do /Herwig/Particles/s:AdjustNominalMass
do /Herwig/Particles/sbar:AdjustNominalMass
do /Herwig/Particles/c:AdjustNominalMass
do /Herwig/Particles/cbar:AdjustNominalMass
do /Herwig/Particles/b:AdjustNominalMass
do /Herwig/Particles/bbar:AdjustNominalMass

##################################################
# DIS physics parameters
##################################################

# DISABLE HADRONIZATION
set EventGenerator:EventHandler:HadronizationHandler  NULL
set /Herwig/Analysis/Basics:CheckQuark false

# disable all shower
# set /Herwig/EventHandlers/EventHandler:CascadeHandler NULL
set /Herwig/Shower/ShowerHandler:LimitEmissions HardOnly
set /Herwig/Shower/ShowerHandler:UseConstituentMasses No
set /Herwig/EventHandlers/EventHandler:DecayHandler NULL


##################################################
# NLO IN POWHEG SCHEME — PHOTON ONLY
##################################################

cd /Herwig/Shower
set ShowerHandler:HardEmission POWHEG

cd /Herwig/MatrixElements/

get MEDISNC:UseNativeDISWindowGeneration
set MEDISNC:UseNativeDISWindowGeneration Yes
get MEDISNC:UseNativeDISWindowGeneration
get MEDISNCPol:UseNativeDISWindowGeneration
set MEDISNCPol:UseNativeDISWindowGeneration Yes
get MEDISNCPol:UseNativeDISWindowGeneration
get PowhegMEDISNC:UseNativeDISWindowGeneration
set PowhegMEDISNC:UseNativeDISWindowGeneration Yes
get PowhegMEDISNC:UseNativeDISWindowGeneration
get PowhegMEDISNCPol:UseNativeDISWindowGeneration
set PowhegMEDISNCPol:UseNativeDISWindowGeneration Yes
get PowhegMEDISNCPol:UseNativeDISWindowGeneration
get MEDISNC:UseFiniteWidthSpacelikeZPropagator
set MEDISNC:UseFiniteWidthSpacelikeZPropagator Yes
get MEDISNC:UseFiniteWidthSpacelikeZPropagator
get MEDISNCPol:UseFiniteWidthSpacelikeZPropagator
set MEDISNCPol:UseFiniteWidthSpacelikeZPropagator Yes
get MEDISNCPol:UseFiniteWidthSpacelikeZPropagator
get PowhegMEDISNC:UseFiniteWidthSpacelikeZPropagator
set PowhegMEDISNC:UseFiniteWidthSpacelikeZPropagator Yes
get PowhegMEDISNC:UseFiniteWidthSpacelikeZPropagator
get PowhegMEDISNCPol:UseFiniteWidthSpacelikeZPropagator
set PowhegMEDISNCPol:UseFiniteWidthSpacelikeZPropagator Yes
get PowhegMEDISNCPol:UseFiniteWidthSpacelikeZPropagator

# set MEDISNC:SamplingPower 0.2
# set MEDISNCPol:SamplingPower 0.2
# set PowhegMEDISNC:SamplingPower 0.2
# set PowhegMEDISNCPol:SamplingPower 0.2

## Neutral current DIS -- POLARIZED, PHOTON ONLY
insert SubProcess:MatrixElements[0] PowhegMEDISNCPol
set PowhegMEDISNCPol:GammaZ Z
set PowhegMEDISNCPol:Contribution NegativeNLO

# Use NLOAlphaS (2-loop) with α_s(MZ)=0.118
set /Herwig/Model:QCD/RunningAlphaS /Herwig/Couplings/NLOAlphaS
set /Herwig/Model:QCD/AlphaS 0.118
set /Herwig/MatrixElements/PowhegMEDISNCPol:UseFixedOrderAlphaSInPOWHEGEmission No
set /Herwig/MatrixElements/PowhegMEDISNCPol:UseQ2ScaleInPOWHEGEmission No
set /Herwig/MatrixElements/PowhegMEDISNCPol:DISDiagnostics Off
set /Herwig/MatrixElements/PowhegMEDISNCPol:DumpNLOTermDiagnostics No
set /Herwig/MatrixElements/PowhegMEDISNCPol:DumpPOWHEGRawMomenta No
set /Herwig/MatrixElements/PowhegMEDISNCPol:POWHEGEmissionComparisonMode Default
set /Herwig/MatrixElements/PowhegMEDISNCPol:POWHEGEmissionComparisonMaxAttempts 100
set /Herwig/MatrixElements/MEDISNC:UsePOWHEGRealSpinVertex No
set /Herwig/MatrixElements/MEDISNC:DiagnosePOWHEGRealSpinVertex No
set /Herwig/MatrixElements/PowhegMEDISNCPol:UsePOWHEGRealSpinVertex No
set /Herwig/MatrixElements/PowhegMEDISNCPol:DiagnosePOWHEGRealSpinVertex No

set /Herwig/Particles/W+:NominalMass 80.450
set /Herwig/Particles/W-:NominalMass 80.450

# ---- Match POLDIS EW parameters ----
set /Herwig/Model:EW/Scheme alphaMZScheme
set /Herwig/Model:EW/AlphaEMMZ 0.00729927
set /Herwig/Model:EW/AlphaEM   0.00729927
set /Herwig/Vertices/FFPVertex:Coupling FixedSM
set /Herwig/Vertices/FFZVertex:Coupling FixedSM


##################################################
## prepare for Rivet analysis or HepMC output
##################################################
read snippets/Rivet.in
# HERA F2
#insert /Herwig/Analysis/Rivet:Analyses 0 HERA_2015_I1377206
# ZEUS D production
#insert /Herwig/Analysis/Rivet:Analyses 0 ZEUS_2008_I810112
# MC DIS EXTRA
insert /Herwig/Analysis/Rivet:Analyses 0 MC_DIS_BREIT:JETINPUT=TOP2PARTONS

##################################################
# Save run
##################################################
cd /Herwig/Generators
get /Herwig/Model:EW/Scheme
get /Herwig/Model:EW/AlphaEMMZ
get /Herwig/Vertices/FFPVertex:Coupling
saverun DIS-POL-POWHEG_MM-NEGNLO-Z-RIVETFO EventGenerator
