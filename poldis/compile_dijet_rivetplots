#!/usr/bin/env bash
set -euo pipefail

script_dir=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)
fc=${FC:-gfortran}

if ! command -v "$fc" >/dev/null 2>&1; then
  echo "error: Fortran compiler '$fc' was not found" >&2
  exit 1
fi

if ! command -v lhapdf-config >/dev/null 2>&1; then
  echo "error: lhapdf-config was not found; please make LHAPDF available in PATH" >&2
  exit 1
fi

read -r -a lhapdf_flags <<< "$(lhapdf-config --ldflags --libs)"

exec "$fc" "$@" \
  "$script_dir/poldis.f" \
  "$script_dir/gbook.f" \
  "$script_dir/jetalg.f" \
  "$script_dir/user_dijet_rivetplots.f" \
  -o "$script_dir/poldis.x" \
  "${lhapdf_flags[@]}"
